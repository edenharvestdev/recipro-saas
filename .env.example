# ============================================================
# Recipro — ตัวแปรสภาพแวดล้อม (คัดลอกเป็น .env แล้วใส่ค่าจริง)
# สแตก: Railway + Node/Express + PostgreSQL + JWT + Omise
# ============================================================

# ---- ฐานข้อมูล PostgreSQL (Railway) ----
# Railway จะใส่ให้อัตโนมัติเมื่อเพิ่ม PostgreSQL plugin
# ตอน dev เครื่องตัวเอง: postgres://user:pass@localhost:5432/recipro
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/recipro

# ---- เซิร์ฟเวอร์ Node ----
PORT=3000                                     # Railway ใส่ค่าให้เอง ตอน deploy
APP_URL=https://app.recipro.co                # โดเมนจริง ไว้ทำลิงก์กลับหลังจ่ายเงิน
NODE_ENV=production

# ---- ล็อกอิน (JWT) — ฝั่งเซิร์ฟเวอร์เท่านั้น! ----
JWT_SECRET=ใส่สตริงสุ่มยาว ๆ อย่างน้อย 32 ตัวอักษร
JWT_EXPIRES_IN=15m                            # อายุ access token
JWT_REFRESH_SECRET=ใส่สตริงสุ่มอีกชุดสำหรับ refresh token
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12                              # ความเข้มของการ hash รหัสผ่าน

# ---- ระบบจ่ายเงิน: Omise / Opn (ไทย) ----
OMISE_PUBLIC_KEY=pkey_xxx                      # ใช้ฝั่ง frontend ได้ (สร้าง token บัตร)
OMISE_SECRET_KEY=skey_xxx                      # server เท่านั้น! ใช้ตัดบัตร + ตรวจ webhook

# ---- รอบบิล / ผ่อนผัน ----
GRACE_DAYS=3                                   # ค้างชำระเกินกี่วันถึงพักร้าน (เฟส C #4)

# ---- อีเมลแจ้งเตือน/ใบเสร็จ (เฟส D #2) ----
RESEND_API_KEY=re_xxx                          # หรือใช้ SMTP ด้านล่างแทน
MAIL_FROM=Recipro <noreply@recipro.co>
# SMTP_HOST= ; SMTP_PORT= ; SMTP_USER= ; SMTP_PASS=

# ============================================================
# ฝั่ง frontend (frontend/app-config.js) ใส่แค่ค่าที่เปิดเผยได้:
#   API_BASE_URL    = https://app.recipro.co   (หรือ URL ของ Node API)
#   OMISE_PUBLIC_KEY = pkey_xxx
# ห้ามใส่ JWT_SECRET / OMISE_SECRET_KEY / DATABASE_URL ใน frontend เด็ดขาด
# ============================================================
